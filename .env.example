# ---- x402-seller configuration ----

# The wallet address that RECEIVES payments (USDC lands here).
# Leave blank to use the auto-generated wallet in wallet.json.
# Swap in your own address when you have one.
PAY_TO=

# Network. Testnet by default so it runs with zero money / zero keys.
#   Base Sepolia (testnet): eip155:84532
#   Base mainnet (real $):  eip155:8453
NETWORK=eip155:84532

# Facilitator (settles the on-chain payment; does not hold your money).
#   Testnet (keyless):  https://x402.org/facilitator
#   Mainnet (needs CDP API keys): https://api.cdp.coinbase.com/platform/v2/x402
FACILITATOR_URL=https://x402.org/facilitator

# Server port
PORT=4021

# ---- test buyer client only (src/client.ts) ----
# A throwaway testnet private key used to PAY for a request in the demo.
# Never put a real / funded mainnet key here.
BUYER_PRIVATE_KEY=
# The URL the client should hit
TARGET_URL=http://localhost:4021/price/BTC
